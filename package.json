{
  "name": "@wince/source",
  "version": "0.0.0",
  "packageManager": "bun@1.3.10",
  "license": "MIT",
  "private": true,
  "scripts": {
    "clean": "nx clean",
    "lint": "nx lint",
    "lint:fix": "nx lint --fix",
    "format": "nx format:write",
    "test": "nx test",
    "build:all": "bun nx run-many --target=build --all",
    "dev": "bunx concurrently \"bunx nx watch --all -- echo \\$NX_PROJECT_NAME\" \"bunx live-server . --port=8000\"",
    "build:web": "cd packages/web && bun run build",
    "generate-mangled": "cd packages/web && bun run generate-mangled",
    "watch:web": "cd packages/web && bun run watch",
    "build:analyze": "cd packages/web && ANALYZE=true bun run build",
    "analyse:web": "cd packages/web && bun run build:analyze",
    "check-mangled": "cd packages/web && bun run check-mangled",
    "size": "cd packages/web && bun run size",
    "test-gzip": "cd packages/web && bun run test-gzip",
    "typecheck": "bun nx run-many -t typecheck --all",
    "format:check": "nx format:check",
    "ci": "bun run typecheck && bun run lint && bun run test && bun run build:all && bun run check-mangled && bun run size"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/rollup": "22.7.5",
    "@rollup/plugin-alias": "^4.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "~0.2.38",
    "@types/jest": "~30.0.0",
    "@types/node": "20.19.9",
    "concurrently": "^8.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jsonc-eslint-parser": "^2.1.0",
    "live-server": "^1.2.2",
    "nx": "22.7.5",
    "prettier": "^3.8.1",
    "rollup": "^4.14.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "swc-loader": "0.1.15",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
