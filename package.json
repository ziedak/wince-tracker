{
  "name": "@wince/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "clean:dep": "rm -rf node_modules && bun -r exec rm -rf node_modules",
    "clean": "nx clean",
    "build:all": "bun nx run-many --target=build --all",
    "dev": "bunx concurrently \"bunx nx build @wince/utils --watch\" \"bunx nx build @wince/core --watch\" \"cd packages/web && bun run watch\" \"bunx live-server . --port=8000\"",
    "dev2": "bunx concurrently \"bunx nx watch --all -- echo \\$NX_PROJECT_NAME\" \"bunx live-server . --port=8000\"",
    "build:web": "cd packages/web && bun run build",
    "postbuild:web": "mkdir -p sandbox/vendor && cp packages/web/dist/index.umd.js sandbox/vendor/index.umd.js",
    "watch:web": "cd packages/web && bun run watch"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/rollup": "22.7.5",
    "@rollup/plugin-alias": "^4.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "~0.2.38",
    "@types/jest": "~30.0.0",
    "@types/node": "20.19.9",
    "concurrently": "^8.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jsonc-eslint-parser": "^2.1.0",
    "live-server": "^1.2.2",
    "nx": "22.7.5",
    "prettier": "^3.8.1",
    "rollup": "^4.14.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-terser": "^7.0.2",
    "swc-loader": "0.1.15",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
