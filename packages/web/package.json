{
  "name": "@wince/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "browser": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.cjs.js"
    },
    "./lite": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.lite.esm.js",
      "require": "./dist/index.lite.cjs.js",
      "default": "./dist/index.lite.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate-mangled": "bun ./scripts/write-mangled-property-names.mjs",
    "check-mangled": "bun ./scripts/check-mangled-property-consistency.mjs",
    "prebuild": "bun run generate-mangled",
    "build": "rollup -c",
    "test-gzip": "bun ./scripts/test-gzip.ts",
    "watch": "rollup -c -w",
    "build:analyze": "ANALYZE=true rollup -c"
  },
  "devDependencies": {
    "rollup-plugin-visualizer": "^6.0.3"
  },
  "dependencies": {
    "@wince/core": "workspace:*",
    "@wince/utils": "workspace:*"
  }
}
