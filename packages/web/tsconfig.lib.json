{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "declaration": true,
    "declarationMap": false,
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "Bundler",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../storage/tsconfig.lib.json"
    },
    {
      "path": "../cache/tsconfig.lib.json"
    },
    {
      "path": "../consent/tsconfig.lib.json"
    },
    {
      "path": "../transport/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
