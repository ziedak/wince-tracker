{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "Bundler",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
